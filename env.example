# Docker Compose Environment Variables
# Modify this file to customize Docker configuration

# Project name (used for container and network prefixes)
COMPOSE_PROJECT_NAME=laravel-blade

# Container names
CONTAINER_APP=laravel-blade-app
CONTAINER_NGINX=laravel-blade-nginx
CONTAINER_DB=laravel-blade-db
CONTAINER_REDIS=laravel-blade-redis
CONTAINER_PHPMYADMIN=laravel-blade-phpmyadmin

# Exposed ports (modify if conflicts with other services)
PORT_NGINX=8080
PORT_MYSQL=3307
PORT_REDIS=6380
PORT_PHPMYADMIN=8082

# Database Configuration
MYSQL_DATABASE=laravel
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=laravel
MYSQL_PASSWORD=laravel

# Traefik Configuration
TRAEFIK_ENABLE=true
TRAEFIK_NETWORK=webproxy
TRAEFIK_DOMAIN=laravel-blade.domain.com
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=cloudflare

# Image versions
PHP_VERSION=8.2-fpm
MYSQL_VERSION=8.0
NGINX_VERSION=alpine
REDIS_VERSION=alpine

# Platform (linux/arm64 for Raspberry Pi, linux/amd64 for x86 systems)
PLATFORM=linux/arm64
